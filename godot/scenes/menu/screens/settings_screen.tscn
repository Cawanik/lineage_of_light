[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/menu/screens/settings_screen.gd" id="1_script"]

[node name="SettingsScreen" type="ScrollContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Center" type="CenterContainer" parent="."]
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="VBox" type="VBoxContainer" parent="Center"]
custom_minimum_size = Vector2(360, 0)
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Center/VBox"]
horizontal_alignment = 1
text = "Настройки"
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.91, 0.878, 1, 1)

[node name="MasterVolume" type="HBoxContainer" parent="Center/VBox"]
