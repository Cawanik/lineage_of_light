[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/menu/screens/hub_screen.gd" id="1_script"]

[node name="HubScreen" type="VBoxContainer"]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_right = 150.0
offset_top = -100.0
offset_bottom = 100.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 14
script = ExtResource("1_script")

[node name="Title" type="Label" parent="."]
horizontal_alignment = 1
text = "Остров"
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.91, 0.878, 1, 1)

[node name="Souls" type="Label" parent="."]
horizontal_alignment = 1
text = "Души: 0"
theme_override_font_sizes/font_size = 14
theme_override_colors/font_color = Color(0.941, 0.816, 0.376, 1)

[node name="SkillTree" type="Button" parent="."]
custom_minimum_size = Vector2(280, 50)
text = "Древо Талантов"

[node name="Map" type="Button" parent="."]
custom_minimum_size = Vector2(280, 50)
text = "Карта"

[node name="Back" type="Button" parent="."]
custom_minimum_size = Vector2(280, 50)
text = "← Назад"

[connection signal="pressed" from="SkillTree" to="." method="_on_skill_tree_pressed"]
[connection signal="pressed" from="Map" to="." method="_on_map_pressed"]
[connection signal="pressed" from="Back" to="." method="_on_back_pressed"]
