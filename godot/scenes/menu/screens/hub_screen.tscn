[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/menu/screens/hub_screen.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/sprites/ui/icon_soul.png" id="2_soul"]

[node name="HubScreen" type="CenterContainer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Inner" type="VBoxContainer" parent="."]
theme_override_constants/separation = 14
script = ExtResource("1_script")

[node name="Title" type="Label" parent="Inner"]
horizontal_alignment = 1
auto_translate_mode = 1
text = "MENU_HUB_TITLE"
theme_override_font_sizes/font_size = 22
theme_override_colors/font_color = Color(0.91, 0.878, 1, 1)

[node name="SoulsContainer" type="HBoxContainer" parent="Inner"]
alignment = 1
theme_override_constants/separation = 6

[node name="SoulIcon" type="TextureRect" parent="Inner/SoulsContainer"]
texture_filter = 1
custom_minimum_size = Vector2(20, 20)
texture = ExtResource("2_soul")
expand_mode = 3
stretch_mode = 6

[node name="Souls" type="Label" parent="Inner/SoulsContainer"]
text = "0"
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.941, 0.816, 0.376, 1)

[node name="Map" type="Button" parent="Inner"]
custom_minimum_size = Vector2(280, 50)
auto_translate_mode = 1
text = "MENU_PLAY"

[node name="SkillTree" type="Button" parent="Inner"]
custom_minimum_size = Vector2(280, 50)
auto_translate_mode = 1
text = "UI_SKILL_TREE_TITLE"

[node name="Back" type="Button" parent="Inner"]
custom_minimum_size = Vector2(280, 50)
auto_translate_mode = 1
text = "MENU_BACK"

[connection signal="pressed" from="Inner/Map" to="Inner" method="_on_map_pressed"]
[connection signal="pressed" from="Inner/SkillTree" to="Inner" method="_on_skill_tree_pressed"]
[connection signal="pressed" from="Inner/Back" to="Inner" method="_on_back_pressed"]
